<Window x:Class="MysticRiver.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:MysticRiver.Client.Views"
        mc:Ignorable="d"
        Title="Mystic River"
        Height="720"
        Width="1280"
        MinHeight="640"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <views:MainMenuView x:Name="MenuView" SinglePlayerRequested="MenuView_SinglePlayerRequested" />
        <views:BattleView x:Name="BattleView" Visibility="Collapsed" />
    </Grid>
</Window>
