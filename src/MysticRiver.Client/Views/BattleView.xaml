<UserControl x:Class="MysticRiver.Client.Views.BattleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,12,10" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="Background" Value="#E62D3546" />
            <Setter Property="Foreground" Value="#FFF5F7FA" />
            <Setter Property="BorderBrush" Value="#FF8FA6D9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://siteoforigin:,,,/Assets/Placeholders/battle-background.png" Stretch="UniformToFill" />
        </Grid.Background>

        <Rectangle Fill="#7F10131A" />

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Width="280"
                    Padding="12"
                    HorizontalAlignment="Left"
                    Background="#CC111827"
                    BorderBrush="#AA9AAED6"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="20" FontWeight="Bold" Foreground="#FFE5E7EB" Text="Turn Order" />
                    <TextBlock x:Name="TurnOrderDescriptionTextBlock" Margin="0,2,0,0" Foreground="#FFBFC7D5" Text="Initializing live connection..." />
                    <StackPanel Margin="0,10,0,0">
                        <Border Margin="0,0,0,6" Padding="8,6" Background="#66283149" CornerRadius="6">
                            <TextBlock x:Name="TurnOrderLine1TextBlock" Foreground="#FFF3F4F6" Text="1. Knight of the River (You)" />
                        </Border>
                        <Border Margin="0,0,0,6" Padding="8,6" Background="#663C2A36" CornerRadius="6">
                            <TextBlock x:Name="TurnOrderLine2TextBlock" Foreground="#FFF3F4F6" Text="2. Wraith Duelist (Enemy)" />
                        </Border>
                        <Border Margin="0,0,0,6" Padding="8,6" Background="#66283149" CornerRadius="6">
                            <TextBlock x:Name="TurnOrderLine3TextBlock" Foreground="#FFF3F4F6" Text="3. Knight of the River (You)" />
                        </Border>
                        <Border Padding="8,6" Background="#663C2A36" CornerRadius="6">
                            <TextBlock x:Name="TurnOrderLine4TextBlock" Foreground="#FFF3F4F6" Text="4. Wraith Duelist (Enemy)" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" Margin="0,16,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="260"
                        Padding="10"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Background="#D8272F3D"
                        BorderBrush="#FFB0C7FF"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <Image Width="220"
                               Height="220"
                               HorizontalAlignment="Center"
                               Source="pack://siteoforigin:,,,/Assets/Placeholders/hero-placeholder.png"
                               Stretch="UniformToFill" />
                        <TextBlock x:Name="PlayerNameTextBlock" Margin="0,8,0,0" FontSize="16" FontWeight="Bold" Foreground="#FFF8FAFC" Text="Knight of the River" />
                        <TextBlock x:Name="PlayerStatsTextBlock" Foreground="#FFE2E8F0" Text="HP 120/120 | Initiative 15" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Margin="24,0"
                        Padding="20,14"
                        VerticalAlignment="Center"
                        Background="#D90F172A"
                        BorderBrush="#FF9FB5E9"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <TextBlock x:Name="RoundTextBlock" HorizontalAlignment="Center" FontSize="24" FontWeight="Bold" Foreground="#FFF4F4F5" Text="Round 1" />
                        <TextBlock x:Name="BattleStatusTextBlock" Margin="0,8,0,0" HorizontalAlignment="Center" Foreground="#FFD1D5DB" Text="Starting battle..." />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Width="260"
                        Padding="10"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Background="#D83A2432"
                        BorderBrush="#FFFFBCC8"
                        BorderThickness="1"
                        CornerRadius="10">
                    <StackPanel>
                        <Image Width="220"
                               Height="220"
                               HorizontalAlignment="Center"
                               Source="pack://siteoforigin:,,,/Assets/Placeholders/enemy-placeholder.png"
                               Stretch="UniformToFill" />
                        <TextBlock x:Name="EnemyNameTextBlock" Margin="0,8,0,0" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Foreground="#FFF8FAFC" Text="Wraith Duelist" />
                        <TextBlock x:Name="EnemyStatsTextBlock" HorizontalAlignment="Right" Foreground="#FFE2E8F0" Text="HP 110/110 | Initiative 10" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Padding="14"
                    Background="#D90F172A"
                    BorderBrush="#AA9AAED6"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#FFF1F5F9" Text="Actions" />
                    <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Abilities}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource ActionButtonStyle}"
                                        Click="AbilityButton_Click"
                                        Content="{Binding Label}"
                                        IsEnabled="{Binding IsEnabled}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
